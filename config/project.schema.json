{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/termbase/project.schema.json",
  "title": "TermBase Project Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "term",
    "character_reference_root_dir",
    "opening_template",
    "ending_template",
    "tone",
    "target_duration_sec",
    "scene_count",
    "image_aspect_ratio",
    "output_dir",
    "llm_provider",
    "llm_model",
    "voice_models",
    "character_design_profiles"
  ],
  "properties": {
    "term": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80
    },
    "character_reference_root_dir": {
      "type": "string",
      "minLength": 1
    },
    "opening_template": {
      "type": "string",
      "minLength": 1,
      "maxLength": 800
    },
    "ending_template": {
      "type": "string",
      "minLength": 1,
      "maxLength": 500
    },
    "tone": {
      "type": "string",
      "minLength": 1,
      "maxLength": 40
    },
    "target_duration_sec": {
      "type": "integer",
      "minimum": 60,
      "maximum": 300
    },
    "scene_count": {
      "type": "integer",
      "minimum": 10,
      "maximum": 15
    },
    "image_aspect_ratio": {
      "type": "string",
      "enum": [
        "9:16"
      ]
    },
    "output_dir": {
      "type": "string",
      "minLength": 1
    },
    "llm_provider": {
      "type": "string",
      "enum": [
        "openai",
        "gemini"
      ]
    },
    "llm_model": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "default": "gpt-5.4"
    },
    "llm_temperature": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "default": 0.3
    },
    "openai_base_url": {
      "type": "string",
      "format": "uri"
    },
    "image_prompt_use_llm": {
      "type": "boolean",
      "default": false
    },
    "image_backend": {
      "type": "string",
      "enum": [
        "comfyui",
        "openai",
        "gemini",
        "imagen"
      ],
      "default": "openai"
    },
    "openai_image_model": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "default": "gpt-image-1"
    },
    "gemini_base_url": {
      "type": "string",
      "format": "uri",
      "default": "https://generativelanguage.googleapis.com/v1beta"
    },
    "gemini_image_model": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "default": "gemini-3.1-flash-image-preview"
    },
    "imagen_model": {
      "type": "string",
      "minLength": 1,
      "maxLength": 120,
      "default": "imagen-3.0-generate-002"
    },
    "comfyui_base_url": {
      "type": "string",
      "format": "uri",
      "default": "http://127.0.0.1:8188"
    },
    "image_workflow_path": {
      "type": "string",
      "minLength": 1
    },
    "comfyui_checkpoint_name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200,
      "default": "sd_xl_base_1.0.safetensors"
    },
    "comfyui_steps": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "default": 20
    },
    "comfyui_cfg_scale": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 30.0,
      "default": 6.5
    },
    "comfyui_timeout_sec": {
      "type": "number",
      "exclusiveMinimum": 0.0,
      "maximum": 3600.0,
      "default": 600.0
    },
    "comfyui_poll_interval_sec": {
      "type": "number",
      "exclusiveMinimum": 0.0,
      "maximum": 60.0,
      "default": 2.0
    },
    "image_width": {
      "type": "integer",
      "minimum": 256,
      "maximum": 2048,
      "default": 832
    },
    "image_height": {
      "type": "integer",
      "minimum": 256,
      "maximum": 4096,
      "default": 1216
    },
    "voice_backend": {
      "type": "string",
      "enum": [
        "style-bert-vits2",
        "google-cloud-tts"
      ],
      "default": "style-bert-vits2"
    },
    "voice_models": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "teacher",
        "student"
      ],
      "properties": {
        "teacher": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        },
        "student": {
          "type": "string",
          "minLength": 1,
          "maxLength": 80
        }
      }
    },
    "google_application_credentials_path": {
      "type": "string",
      "minLength": 1
    },
    "google_tts_language_code": {
      "type": "string",
      "minLength": 2,
      "maxLength": 20,
      "default": "ja-JP"
    },
    "google_tts_audio_encoding": {
      "type": "string",
      "enum": [
        "mp3",
        "linear16"
      ],
      "default": "mp3"
    },
    "google_tts_speaking_rate": {
      "type": "number",
      "minimum": 0.25,
      "maximum": 4.0,
      "default": 1.0
    },
    "google_tts_use_ssml": {
      "type": "boolean",
      "default": true
    },
    "google_tts_voice_tunings": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "teacher",
        "student"
      ],
      "properties": {
        "teacher": {
          "$ref": "#/$defs/googleTtsVoiceTuning"
        },
        "student": {
          "$ref": "#/$defs/googleTtsVoiceTuning"
        }
      }
    },
    "google_tts_section_speaking_rates": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "opening",
        "ending"
      ],
      "properties": {
        "opening": {
          "$ref": "#/$defs/googleTtsSectionSpeakingRate"
        },
        "ending": {
          "$ref": "#/$defs/googleTtsSectionSpeakingRate"
        }
      }
    },
    "overlay_font_path": {
      "type": "string",
      "minLength": 1
    },
    "character_design_profiles": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "teacher",
        "student"
      ],
      "properties": {
        "teacher": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "student": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        }
      }
    },
    "retry_count": {
      "type": "integer",
      "minimum": 0,
      "maximum": 5,
      "default": 2
    },
    "additional_instructions": {
      "type": "string",
      "maxLength": 2000
    }
  },
  "$defs": {
    "googleTtsVoiceTuning": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "speaking_rate",
        "pitch_semitones"
      ],
      "properties": {
        "speaking_rate": {
          "type": "number",
          "minimum": 0.25,
          "maximum": 4.0
        },
        "pitch_semitones": {
          "type": "number",
          "minimum": -20.0,
          "maximum": 20.0
        },
        "sentence_break_ms": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5000
        },
        "question_break_ms": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5000
        },
        "comma_break_ms": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5000
        },
        "question_pitch_delta_semitones": {
          "type": "number",
          "minimum": -20.0,
          "maximum": 20.0
        }
      }
    },
    "googleTtsSectionSpeakingRate": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "teacher": {
          "type": ["number", "null"],
          "minimum": 0.25,
          "maximum": 4.0
        },
        "student": {
          "type": ["number", "null"],
          "minimum": 0.25,
          "maximum": 4.0
        }
      }
    }
  }
}